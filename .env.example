DB_PROTOCOL=mysql+aiomysql
DB_USER=root
DB_PASSWORD=root
DB_HOST=db
DB_PORT=3306
DB_NAME=delivery

REDIS_HOST=redis
REDIS_BIND=0.0.0.0
REDIS_PROTECTED=yes
REDIS_PORT=6379
REDIS_PASS=yourstrongpass

LOG_LEVEL=INFO
ENVIRONMENT=prod

# Delivery formula
DELIVERY_WEIGHT_COEFF=0.5
DELIVERY_VALUE_COEFF=0.01
DELIVERY_BATCH_SIZE=500
DELIVERY_LOCK_TTL=330
DELIVERY_JOB_INTERVAL_MIN=5

# Cache TTL (seconds)
CACHE_TTL_DEFAULT=60
CACHE_TTL_RATE=600
