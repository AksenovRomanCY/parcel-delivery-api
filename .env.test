DB_PROTOCOL=mysql+aiomysql
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=delivery_test

REDIS_HOST=127.0.0.1
REDIS_BIND=0.0.0.0
REDIS_PROTECTED=yes
REDIS_PORT=6379
REDIS_PASS=yourstrongpass

LOG_LEVEL=INFO
ENVIRONMENT=test

# Delivery formula
DELIVERY_WEIGHT_COEFF=0.5
DELIVERY_VALUE_COEFF=0.01
DELIVERY_BATCH_SIZE=500
DELIVERY_LOCK_TTL=330
DELIVERY_JOB_INTERVAL_MIN=5

# Cache TTL (seconds)
CACHE_TTL_DEFAULT=60
CACHE_TTL_RATE=600

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_CREATE=20/minute
RATE_LIMIT_LIST=60/minute
RATE_LIMIT_DETAIL=60/minute
RATE_LIMIT_PARCEL_TYPES=100/minute
RATE_LIMIT_RECALC=5/minute

# JWT Authentication
JWT_SECRET_KEY=change-me-in-tests-use-32-bytes-minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MIN=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=parcel-delivery-api
JWT_AUDIENCE=parcel-delivery-clients
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=refresh_csrf
CSRF_HEADER_NAME=X-CSRF-Token
AUTH_REQUIRED=false
TASK_ADMIN_TOKEN=

# Observability
ENABLE_METRICS=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
